generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String?
  language     String        @default("en")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  wallets      Wallet[]
  categories   Category[]
  budgets      Budget[]
  savingGoals  SavingGoal[]
  credits      Credit[]
  budgetPeriods BudgetPeriod[]
  subscriptions Subscription[]
}

model Wallet {
  id           String        @id @default(uuid())
  userId       String
  name         String
  balance      Float         @default(0)
  currency     String        @default("USD")
  order        Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions       Transaction[] @relation("SourceWallet")
  targetTransactions Transaction[] @relation("TargetWallet")
  subscriptions      Subscription[]
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum BudgetStatus {
  DRAFT
  ACTIVE
  FINISHED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum SubscriptionFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Category {
  id           String        @id @default(uuid())
  name         String
  type         TransactionType
  color        String        @default("#6b7280")
  icon         String        @default("Tag")
  userId       String?       // Optional: null means it's a default/system category
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
  subscriptions Subscription[]
}

model Transaction {
  id              String          @id @default(uuid())
  walletId        String          // Source wallet
  targetWalletId  String?         // Target wallet (for TRANSFER)
  categoryId      String
  transferId      String?         // Kept for backward compatibility during migration
  creditId        String?
  subscriptionId  String?
  amount          Float           // Source amount
  targetAmount    Float?          // Target amount (for TRANSFER)
  creditAmount    Float?          // Amount in credit currency (for credit payments)
  type            TransactionType
  date            DateTime        @default(now())
  description     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  wallet          Wallet          @relation("SourceWallet", fields: [walletId], references: [id], onDelete: Cascade)
  targetWallet    Wallet?         @relation("TargetWallet", fields: [targetWalletId], references: [id], onDelete: SetNull)
  category        Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transfer        Transfer?       @relation(fields: [transferId], references: [id], onDelete: Cascade)
  credit          Credit?         @relation(fields: [creditId], references: [id], onDelete: SetNull)
  subscription    Subscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
}

model Transfer {
  id               String        @id @default(uuid())
  sourceWalletId   String
  targetWalletId   String
  sourceAmount     Float
  targetAmount     Float
  exchangeRate     Float         @default(1.0)
  description      String?
  date             DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  transactions     Transaction[]
}

model Budget {
  id           String        @id @default(uuid())
  userId       String
  categoryId   String
  limit        Float
  startDate    DateTime
  endDate      DateTime
  status       BudgetStatus  @default(ACTIVE)
  note         String?
  currency     String        @default("USD")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  periodId     String?
  period       BudgetPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@index([userId, startDate, endDate])
}

model BudgetPeriod {
  id           String        @id @default(uuid())
  userId       String
  name         String
  startDate    DateTime
  endDate      DateTime
  status       BudgetStatus  @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgets      Budget[]

  @@index([userId, status])
}

model SavingGoal {
  id            String        @id @default(uuid())
  userId        String
  name          String
  targetAmount  Float
  currentAmount Float         @default(0)
  currency      String        @default("USD")
  deadline      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Credit {
  id              String        @id @default(uuid())
  userId          String
  name            String
  totalAmount     Float
  paidAmount      Float         @default(0)
  remainingAmount Float         @default(0)
  interestRate    Float?        @default(0)
  monthlyPayment  Float         @default(0)
  currency        String        @default("USD")
  dueDate         DateTime?
  status          String        @default("ACTIVE")
  commission      Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
}

model Subscription {
  id              String                @id @default(uuid())
  userId          String
  categoryId      String?
  name            String
  amount          Float
  currency        String                @default("USD")
  frequency       SubscriptionFrequency @default(MONTHLY)
  status          SubscriptionStatus    @default(ACTIVE)
  startDate       DateTime              @default(now())
  nextPaymentDate DateTime
  walletId        String
  note            String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  wallet          Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@index([userId, nextPaymentDate])
}
